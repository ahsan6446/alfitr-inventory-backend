# Copy this file to .env and fill in real values before deploying.

# Port the server listens on
PORT=4000

# REQUIRED IN PRODUCTION: a long random secret used to sign login sessions (JWTs).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If this is left unset, the server falls back to an insecure default and prints a warning.
JWT_SECRET=

# Which origin(s) are allowed to call this API from a browser.
# Use your real domain in production, e.g. https://inventory.alfitr-uae.com
# Leave unset (or "*") only for local testing.
CORS_ORIGIN=

# Where to store the database file and uploaded logos.
# Leave unset for local use (defaults to the "data" folder next to this file).
# On a host with a persistent disk (e.g. Render), set this to the disk's mount path,
# e.g. DATA_DIR=/var/data — otherwise your data will be lost on every redeploy.
DATA_DIR=
